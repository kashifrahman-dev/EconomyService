{
  "openapi": "3.0.1",
  "info": {
    "title": "EconomyService",
    "version": "1.0"
  },
  "paths": {
    "/v1/wallets/{playerId}/credit": {
      "post": {
        "tags": [
          "Wallet"
        ],
        "parameters": [
          {
            "name": "playerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreditRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreditRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreditRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
