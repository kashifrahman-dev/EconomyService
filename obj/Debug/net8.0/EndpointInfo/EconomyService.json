  "components": {
    "schemas": {
      "ClaimRewardRequest": {
        "type": "object",
        "properties": {
          "rewardId": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreditRequest": {
        "required": [
          "amount",
          "reason"
        ],
        "type": "object",
        "properties": {
          "amount": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "reason": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PurchaseRequest": {
        "type": "object",
        "properties": {
          "itemName": {
            "type": "string",
            "nullable": true
          },
          "cost": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
  }
